{
  "manifest_version": 3,
  "name": "Maximum Notificacoes",
  "version": "2.0.2",
  "description": "Monitora obrigacoes, processos e solicitacoes do Acessorias com um painel lateral moderno em tema light marsala.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://app.acessorias.com/*",
    "https://api.acessorias.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.acessorias.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
